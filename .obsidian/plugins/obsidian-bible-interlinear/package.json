{
	"name": "obsidian-bible-interlinear",
	"version": "1.0.0",
	"description": "Interlinear Bible study plugin for Obsidian",
	"main": "main.js",
	"scripts": {
		"build": "esbuild src/main.ts --bundle --external:obsidian --external:@codemirror/view --external:@codemirror/state --format=cjs --outfile=main.js",
		"dev": "esbuild src/main.ts --bundle --external:obsidian --external:@codemirror/view --external:@codemirror/state --format=cjs --outfile=main.js --watch"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"esbuild": "^0.20.0",
		"obsidian": "^1.5.0",
		"typescript": "^5.3.0"
	}
}
